# Name of the Backblaze B2 remote created with `rclone config`.
TRADIX_B2_REMOTE=b2

# Private B2 bucket and optional key prefix used by scripts/b2-storage.sh.
TRADIX_B2_BUCKET=tradix-kumetix
TRADIX_B2_PREFIX=tradix

# Abort a mirror if it would delete more remote objects than this.
TRADIX_B2_MAX_DELETE=1000
