# IDE and editor files
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# OS metadata
.DS_Store
Thumbs.db

# Local environment and secrets
.env
.env.*
!.env.example
*.local

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Build and dependency outputs
build/
dist/
out/
target/
node_modules/

# IBKR Flex outputs and local portfolio exports
*.flex.csv
*.flex.xml
ibkr-portfolio-*.csv
ibkr-portfolio-*.xml
portfolio-*.csv
portfolio-*.xml

# B2-backed datasets and generated outputs. Dataset notes travel with the
# canonical CSV payload so their interpretation stays version-aligned.
data/**/*
artifacts/**/*

# Local B2 settings (credentials belong in rclone's user config, not here).
.b2.env
.b2-sync-initialized
.b2-canonical-manifest.json
